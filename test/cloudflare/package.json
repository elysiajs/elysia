{
	"name": "elysia-cf",
	"version": "0.0.0",
	"private": true,
	"scripts": {
		"dev": "wrangler dev",
		"start": "wrangler dev",
		"setup": "rm -rf node_modules/elysia && ln -sf ../../.. node_modules/elysia",
		"gen": "npm run setup && node gen-node.mjs",
		"test": "npm run gen && bun script/smoke.ts",
		"build:standalone": "npm run setup && bun build-standalone.mjs",
		"test:standalone": "npm run build:standalone && bun script/smoke.ts 8801 --no-bundle -c wrangler.standalone.jsonc",
		"cf-typegen": "wrangler types"
	},
	"devDependencies": {
		"esbuild": "0.25.4",
		"typescript": "^5.8.2",
		"wrangler": "^4.40.2"
	},
	"dependencies": {
		"elysia": "../../"
	},
	"overrides": {
		"esbuild": "0.25.4"
	}
}
